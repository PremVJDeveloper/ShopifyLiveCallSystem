# ================================================================
# ShopifyLiveCallSystem — Environment Variables
# Copy this file to .env and fill in your values.
# ================================================================

# ----------------------------------------------------------------
# Server
# ----------------------------------------------------------------
PORT=3000
NODE_ENV=development

# ----------------------------------------------------------------
# Admin Authentication
# ----------------------------------------------------------------
# The username/password for the admin login page.
# Generate a bcrypt hash for your password:
#   node -e "const b=require('bcryptjs'); b.hash('your_password',12).then(console.log)"
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=$2a$12$REPLACE_WITH_YOUR_BCRYPT_HASH

# Secret used to sign JWT tokens (make this a long random string)
JWT_SECRET=replace_with_a_long_random_secret_string_here
JWT_EXPIRES_IN=8h

# ----------------------------------------------------------------
# TURN Server (Required for production — NAT traversal)
# ----------------------------------------------------------------
#
# OPTION A — Self-hosted coturn on your AWS Ubuntu server (RECOMMENDED)
# -----------------------------------------------------------------------
# 1. SSH into your EC2: sudo apt install -y coturn
# 2. Configure /etc/turnserver.conf (see README for full config)
# 3. Generate a secret: openssl rand -hex 32
# 4. Open AWS Security Group ports: UDP/TCP 3478, 5349, UDP 49152-65535
#
TURN_URL=turn:YOUR_EC2_PUBLIC_IP:3478    # your server's public/elastic IP
TURN_USERNAME=vaama                       # any fixed string (auth-secret mode)
TURN_CREDENTIAL=YOUR_OPENSSL_SECRET_HERE  # from: openssl rand -hex 32

# OPTION B — Metered.ca free tier (50 GB/month, zero server setup)
# ------------------------------------------------------------------
# 1. https://app.metered.ca → Create App → TURN Server → copy creds
# TURN_URL=                               # leave blank for Metered
# TURN_USERNAME=your_metered_username
# TURN_CREDENTIAL=your_metered_credential

# ----------------------------------------------------------------
# PostgreSQL (for call history & audit logs)
# ----------------------------------------------------------------
# Format: postgresql://user:password@host:port/database
# Leave blank to run without database (no call history persistence)
DATABASE_URL=postgresql://postgres:password@localhost:5432/livecall_db

# ----------------------------------------------------------------
# Logging
# ----------------------------------------------------------------
LOG_LEVEL=info
